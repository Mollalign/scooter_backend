# =============================================================================
# GreenFlow Mobility — Environment Variables
# Copy this file to `.env` and fill in values. NEVER commit `.env`.
# =============================================================================

# --- Application ---------------------------------------------------------
APP_NAME=GreenFlow Mobility API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1

# --- Database (PostgreSQL + PostGIS) -------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/greenflow
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_USE_SSL=false

# --- JWT Authentication --------------------------------------------------
SECRET_KEY=change-this-to-a-32+char-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ROTATE_REFRESH_TOKENS=true

# --- Chapa Payment Gateway ----------------------------------------------
CHAPA_SECRET_KEY=
CHAPA_PUBLIC_KEY=
CHAPA_WEBHOOK_SECRET=
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_CALLBACK_URL=https://app.greenflow.et/topup/return
CHAPA_WEBHOOK_URL=https://api.greenflow.et/api/v1/webhooks/chapa

# --- SMS gateway (AfroMessage or similar) --------------------------------
SMS_API_KEY=
SMS_API_URL=https://api.afromessage.com/api/send
SMS_SENDER_NAME=GreenFlow

# --- Firebase Cloud Messaging -------------------------------------------
FCM_SERVER_KEY=
FCM_PROJECT_ID=
FCM_CREDENTIALS_JSON=

# --- S3-compatible storage -----------------------------------------------
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=greenflow-uploads
S3_REGION=auto
S3_PUBLIC_BASE_URL=

# --- IoT / MQTT ----------------------------------------------------------
MQTT_BROKER_URL=
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=greenflow-api
MQTT_COMMAND_TOPIC=scooters/{device_id}/cmd
MQTT_TELEMETRY_TOPIC=scooters/+/telemetry
IOT_COMMAND_TIMEOUT_SECONDS=15

# --- Business rules ------------------------------------------------------
RESERVATION_HOLD_MINUTES=10
RIDE_LOST_SIGNAL_MINUTES=10
RIDE_MAX_DURATION_MINUTES=180
MIN_TOPUP_AMOUNT=10
MAX_TOPUP_AMOUNT=10000
LOW_BATTERY_THRESHOLD=15
MIN_RIDE_BATTERY_PERCENT=20

# --- OTP -----------------------------------------------------------------
OTP_EXPIRY_MINUTES=10
MAX_OTP_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# --- CORS ----------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
