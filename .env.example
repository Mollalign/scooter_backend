# =============================================================================
# Scooter Rental System — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# --- Application ---
APP_NAME=ScooterRentalAPI
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/scooter_rental
DATABASE_ECHO=false

# --- JWT Authentication ---
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Chapa Payment Gateway ---
CHAPA_SECRET_KEY=your-chapa-secret-key
CHAPA_WEBHOOK_SECRET=your-chapa-webhook-secret
CHAPA_BASE_URL=https://api.chapa.co/v1

# --- SMS Gateway (e.g., Afro SMS) ---
SMS_API_KEY=your-sms-api-key
SMS_API_URL=https://api.afromessage.com/api/send
SMS_SENDER_NAME=ScooterET

# --- Firebase Cloud Messaging ---
FCM_SERVER_KEY=your-firebase-server-key
FCM_PROJECT_ID=your-firebase-project-id

# --- Cloud Storage (S3-compatible) ---
S3_ENDPOINT_URL=https://your-s3-endpoint.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=scooter-rental-uploads
S3_REGION=auto

# --- Platform Settings ---
PLATFORM_FEE_RATE=0.12
BOOKING_HOLD_MINUTES=15
OTP_EXPIRY_MINUTES=10
MAX_OTP_ATTEMPTS=5

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]
